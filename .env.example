# ─── Application ───────────────────────────────────────────
APP_NAME=Sales Visual API
DEBUG=true
LOG_LEVEL=info
SECRET_KEY=change-me-in-production

# ─── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
PUBLIC_APP_URL=http://localhost:8000

# ─── Monday.com (to be configured) ─────────────────────────
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=5280027820
MONDAY_API_URL=https://api.monday.com/v2

# ─── Database (PostgreSQL — to be added later) ─────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/sales_visual

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Azure Blob Storage
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=sales-visual-files
